# ─────────────────────────────────────────────────────────────────────────────
# Caddyfile — Open Intelligence Lab v0.4.0
#
# Caddy sits in front of the OI Lab API and terminates HTTPS.
# This eliminates the mixed-content block when GitHub Pages (https://)
# tries to call the local API (http://).
#
# With this running:
#   - GitHub Pages at https://alborznazari.github.io calls https://localhost:8443
#   - No mixed content — both sides are HTTPS
#   - Self-signed cert is auto-generated by Caddy (accept once in browser)
#   - No manual cert management required
#
# Inside Docker: Caddy proxies to the oilab container by service name.
# Outside Docker (standalone): Caddy proxies to localhost:8000.
#
# Author: Alborz Nazari
# License: MIT
# ─────────────────────────────────────────────────────────────────────────────

https://localhost:8443 {
    # Auto-generates a self-signed cert — accept the browser warning once
    tls internal

    # Proxy all requests to the OI Lab API
    reverse_proxy oilab:8000

    # CORS headers so GitHub Pages can call this endpoint from any origin
    header Access-Control-Allow-Origin *
    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"

    # Log requests for debugging
    log {
        output stderr
        level INFO
    }
}
